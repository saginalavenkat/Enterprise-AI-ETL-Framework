# ---------------------------------------------------------------------------

.venv/
venv/
env/

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------

.idea/
.vscode/

# ---------------------------------------------------------------------------
# Operating System
# ---------------------------------------------------------------------------

.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
