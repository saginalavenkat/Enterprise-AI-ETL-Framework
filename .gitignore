# ---------------------------------------------------------------------------

.pytest_cache/
.coverage
htmlcov/

# ---------------------------------------------------------------------------
# ChromaDB / Vector Database
# ---------------------------------------------------------------------------

chromadb/
integrations/vectordb/chroma_storage/
resources/vector_db/chroma_storage/

# ---------------------------------------------------------------------------
